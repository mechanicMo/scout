# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# WARNING: Service role key bypasses Row Level Security — NEVER use in mobile app or client-side code
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# TMDB
TMDB_READ_ACCESS_TOKEN=your-tmdb-token

# API
API_PORT=3000
API_URL=http://localhost:3000

# Direct DB connection (for Drizzle migrations — Supabase project settings → Database → Connection string → URI)
SUPABASE_DB_URL=postgresql://postgres:[password]@[host]:5432/postgres

# Groq (AI recommendations via picks.refine)
GROQ_API_KEY=your_groq_api_key
